# Copy this file to .env and fill in your values. Never commit .env to git.

# LLM API
# OpenRouter key (get one at https://openrouter.ai/keys)
OPENAI_API_KEY=sk-or-v1-your-openrouter-key-here

# OpenAI-compatible base URL
# OpenRouter:   https://openrouter.ai/api/v1
# HF router:    https://router.huggingface.co/v1
API_BASE_URL=https://openrouter.ai/api/v1

# Model identifier
# NVIDIA Nemotron 3 Super (free on OpenRouter):
MODEL_NAME=nvidia/llama-3.3-nemotron-super-49b-v1

# Hugging Face token (https://huggingface.co/settings/tokens)
HF_TOKEN=hf_your_token_here
